---
import { getCatalogData, getCatalogDataWithCompany, resolveCompanyAccess } from '../services/notion';
import type { Product, Company } from '../services/notion';
import { getCompanyForCurrentCatalog } from '../services/notion';
import { config } from '../config/filter';
import '../styles/global.css';
import '@fortawesome/fontawesome-free/css/all.min.css';

export const prerender = false;

type ProductWithPrices = Product & {
  priceX25: number;
  priceX100: number;
  pricex250: number;
};

function ensureAbsoluteUrl(value?: string): string {
  const fallback = 'https://mrprinteto.com';
  const raw = (value ?? '').trim();

  if (!raw) return fallback;

  try {
    return new URL(raw).toString();
  } catch {
    try {
      return new URL(`https://${raw}`).toString();
    } catch {
      return fallback;
    }
  }
}

const CDN_IMAGE_OPTIONS = 'width=800,quality=75,format=webp';
function getProductCdnImageUrl(code: string): string {
  if (!code) return '';
  return `https://assets.mrprinteto.com/cdn-cgi/image/${CDN_IMAGE_OPTIONS}/products/b2b/${encodeURIComponent(code)}/1.webp`;
}

const ACCESS_COOKIE_NAME = 'catalog_access_key';
const cookieHmac = Astro.cookies.get(ACCESS_COOKIE_NAME)?.value?.trim() ?? '';
const cookieSecret = import.meta.env.COOKIE_SECRET ?? '';

// Ronda 1 — una única llamada a Notion que resuelve empresa + validación
// simultáneamente. Antes eran dos queries idénticas en paralelo que Notion
// degradaba, causando timeouts y reintentos (~6s extra).
let hasCatalogAccess = false;
let resolvedCompany: Company | null = null;

if (cookieHmac) {
  try {
    const { company, isValid } = await resolveCompanyAccess(cookieHmac, cookieSecret);
    hasCatalogAccess = isValid;
    resolvedCompany = company;
  } catch {
    hasCatalogAccess = false;
  }
} else {
  try {
    resolvedCompany = await getCompanyForCurrentCatalog();
  } catch {
    // Fallback silencioso para no bloquear pantalla de acceso.
  }
}

let products: ProductWithPrices[] = [];
let companyName = config.companySlug || 'tu empresa';
let companySlug = config.companySlug;
let companyUrl = ensureAbsoluteUrl();
let companyLogo = '';
let companyEmail = '';
let companyId = '';

if (resolvedCompany) {
  companyName = resolvedCompany.name || companyName;
  companySlug = resolvedCompany.slug || companySlug;
  companyUrl = ensureAbsoluteUrl(resolvedCompany.url);
  companyLogo = resolvedCompany.logo || '';
  companyEmail = resolvedCompany.email || '';
}

if (hasCatalogAccess) {
  // Ronda 2: queries de productos en paralelo.
  const { company, products: catalogProducts } = resolvedCompany
    ? await getCatalogDataWithCompany(resolvedCompany)
    : await getCatalogData();
  products = [...(catalogProducts as ProductWithPrices[])].sort((a, b) => {
    const customizedDiff = Number(a.customized) - Number(b.customized);
    if (customizedDiff !== 0) return customizedDiff;
    return a.name.localeCompare(b.name, 'es');
  });
  companyName = company?.name || config.companySlug || 'tu empresa';
  companySlug = company?.slug || config.companySlug;
  companyUrl = ensureAbsoluteUrl(company?.url);
  companyLogo = company?.logo || '';
  companyEmail = company?.email || '';
  companyId = company?.id || '';
}

const whatsappMessage = `Hola MrPrinteto, te contacto porque necesito ayuda con mi catalogo de ${companyName}`;
const whatsappUrl = `https://wa.me/34686520345?text=${encodeURIComponent(whatsappMessage)}`;

const canonicalUrl = new URL('/', companyUrl).toString();
const seoTitle = hasCatalogAccess
  ? `Catálogo privado de ${companyName}`
  : 'Acceso privado al catálogo';
const seoDescription = hasCatalogAccess
  ? `Accede a la selección de productos que he preparado para ${companyName}. Personaliza cada artículo con tu marca y solicita tu presupuesto personalizado. ¡Haz que tu marca destaque con nuestros productos exclusivos!`
  : 'Introduce tu clave para acceder al catálogo privado de tu empresa.';
const seoKeywords = hasCatalogAccess
  ? [
      `catálogo ${companyName}`,
      'merchandising personalizado',
      'regalos promocionales',
      'productos corporativos',
      'presupuesto personalizado',
      'impresión personalizada',
    ].join(', ')
  : 'catálogo privado, acceso por clave';

const organizationStructuredData = hasCatalogAccess
  ? {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: companyName,
      url: canonicalUrl,
      logo: companyLogo || undefined,
    }
  : null;

const itemListStructuredData = hasCatalogAccess
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: `Catálogo de ${companyName}`,
      itemListElement: products.slice(0, 24).map((product, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: {
          '@type': 'Product',
          name: product.name || 'Producto',
          description: product.description || 'Producto personalizable.',
          image: product.code ? getProductCdnImageUrl(product.code) : undefined,
          offers: {
            '@type': 'Offer',
            priceCurrency: 'EUR',
            price: typeof product.price === 'number' ? product.price : Number(product.price) || 0,
            availability: 'https://schema.org/InStock',
          },
        },
      })),
    }
  : null;
---

<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>{seoTitle}</title>
  <meta name="description" content={seoDescription} />
  <meta name="keywords" content={seoKeywords} />
  <meta name="author" content={companyName} />
  <meta name="robots" content={hasCatalogAccess ? 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' : 'noindex,nofollow'} />
  <meta name="googlebot" content={hasCatalogAccess ? 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1' : 'noindex,nofollow'} />
  <meta name="theme-color" content="#4f46e5" />
  <meta name="format-detection" content="telephone=no" />

  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="es-ES" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <meta property="og:type" content="website" />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content={companyName} />
  <meta property="og:title" content={seoTitle} />
  <meta property="og:description" content={seoDescription} />
  <meta property="og:url" content={canonicalUrl} />
  {companyLogo && <meta property="og:image" content={companyLogo} />}

  <meta name="twitter:card" content={companyLogo ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={seoTitle} />
  <meta name="twitter:description" content={seoDescription} />
  {companyLogo && <meta name="twitter:image" content={companyLogo} />}

  {organizationStructuredData && (
    <script type="application/ld+json" set:html={JSON.stringify(organizationStructuredData)}></script>
  )}
  {itemListStructuredData && (
    <script type="application/ld+json" set:html={JSON.stringify(itemListStructuredData)}></script>
  )}

  <link href="https://fonts.googleapis.com" rel="preconnect" />
  <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
  <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    rel="stylesheet" />
</head>

<body class="bg-gradient-to-br from-white via-indigo-50 to-indigo-100 text-slate-900">
  {hasCatalogAccess ? (
  <div class="max-w-7xl mx-auto px-6 py-12 md:py-20 ">
    <header class="flex flex-col md:flex-row md:items-center justify-between mb-16 gap-4">
      <div class="order-2 md:order-1 max-w-xl min-w-0">
        <h1 class="text-3xl md:text-6xl font-black text-indigo-500 mb-8 tracking-tight mt-10 md:mt-0 break-words">
          <span class="opacity-50 font-thin">Catálogo</span><br>{companyName}
        </h1>
        <p class="text-slate-600 leading-relaxed text-lg">
          Desde <strong>MrPrinteto</strong>&reg; te presentamos este catálogo de productos para <strong>{companyName}</strong>.
          Creemos que representan la esencia de tu marca y tendrán un impacto en tu audiencia.
        </p>
      </div>
      <div class="order-1 md:order-2 flex-1 flex w-full items-center justify-center" data-tour="1">
        {companyLogo && (
        <img
          src={companyLogo}
          alt={`Logo de ${companyName}`}
          class="block w-screen max-w-none h-auto object-contain -mx-6 md:mx-auto md:w-auto md:max-w-full md:h-48 px-10"
          loading="lazy"
        />
      )}
      </div>
    </header>

    <div class="py-4 text-slate-900 border-y-2 border-slate-200 mb-10">
      <div class="grid gap-12 md:grid-cols-2 my-10">
        <div>
          <p class="text-slate-800 mb-2 font-semibold text-lg flex items-center gap-2">
            <i class="fa fa-piggy-bank text-indigo-400 text-3xl" aria-hidden="true"></i>
            Descuento por volumen
          </p>
          <p class="text-slate-600 mb-2 pl-12">
            Por <strong>cada 25, 100 o 250 unidades</strong> de cada producto aplicamos un descuento adicional.
            Añade productos al presupuesto para ver los descuentos aplicados.
          </p>
        </div>
        <div>
          <p class="text-slate-800 mb-2 font-semibold text-lg flex items-center gap-2">
            <i class="fa fa-pen-ruler text-indigo-400 text-3xl" aria-hidden="true"></i>
            Proyectos personalizados
          </p>
          <p class="text-slate-600 mb-2 pl-12">
            Si buscas algún producto personalizado que no esté incluido en tu catálogo privado, no dudes en ponerte en contacto conmigo mediante 
            <a class="text-slate-900" href="https://wa.me/34686520345?text=Hola%2C%20tengo%20una%20idea%20para%20un%20proyecto%20personalizado">Whatsapp</a>, 
            <a class="text-slate-900" href="mailto:info@mrprinteto.com">Email</a> o 
            <a class="text-slate-900" href="https://www.instagram.com/mrprinteto/">Instagram</a>.
          </p>
        </div>
      </div>
    </div>

    
    <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_360px] gap-6 items-start">
      <div>
        {products.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5" data-tour-products>
            {products.map((product, index) => {
              const productWithPrices = product as ProductWithPrices;
              const rawPrice = typeof productWithPrices.price === 'number' ? productWithPrices.price : Number(productWithPrices.price) || 0;
              const priceX25 = typeof productWithPrices.priceX25 === 'number' ? productWithPrices.priceX25 : Number(productWithPrices.priceX25) || 0;
              const priceX100 = typeof productWithPrices.priceX100 === 'number' ? productWithPrices.priceX100 : Number(productWithPrices.priceX100) || 0;
              const pricex250 = typeof productWithPrices.pricex250 === 'number' ? productWithPrices.pricex250 : Number(productWithPrices.pricex250) || 0;
              const displayPrice = `${rawPrice} €`;
              return (
                <div
                  class="group relative overflow-hidden rounded-2xl border border-slate-200/90 bg-white/90 p-4 md:p-5 flex flex-col shadow-sm transition-all duration-300 hover:-translate-y-3 hover:shadow-xl hover:border-indigo-200"
                  data-product-id={productWithPrices.id}
                  data-product-code={productWithPrices.code || ''}
                  data-product-customized={productWithPrices.customized ? 'true' : 'false'}
                  data-product-name={productWithPrices.name || 'Producto'}
                  data-product-price={rawPrice}
                  data-product-price-x25={priceX25}
                  data-product-price-x100={priceX100}
                  data-product-price-x250={pricex250}
                  {...(index === 0 ? { 'data-tour': '2' } : {})}
                >
                  <div class="flex justify-between items-center mb-4 gap-3">
                    <div>
                      {productWithPrices.customized && (
                        <span class="inline-flex items-center px-3 py-1 rounded-full border border-slate-200 bg-indigo-500 text-xs font-medium text-white">
                          <i class="fa fa-pen-ruler mr-2"></i> Personalizable
                        </span>
                      )}
                    </div>
                    <div class="inline-flex items-center rounded-full border border-indigo-100 bg-indigo-50/70 p-0.5 text-slate-700" aria-label="Control cantidad">
                      <button
                        class="w-7 h-7 rounded-full text-indigo-700 text-sm font-semibold flex items-center justify-center hover:bg-indigo-600 hover:text-white transition disabled:opacity-40 disabled:cursor-not-allowed"
                        type="button"
                        data-action="decrement"
                        aria-label={`Quitar ${productWithPrices.name || 'producto'}`}
                      >
                        −
                      </button>
                      <input
                        type="number"
                        min="0"
                        value="0"
                        inputmode="numeric"
                        class="qty-input w-8 h-7 bg-transparent text-center text-xs font-semibold text-slate-700 focus:outline-none border-0 px-0"
                        data-role="count"
                        aria-label={`Cantidad de ${productWithPrices.name || 'producto'}`}
                      />
                      <button
                        class="w-7 h-7 rounded-full text-indigo-700 text-sm font-semibold flex items-center justify-center hover:bg-indigo-600 hover:text-white transition"
                        type="button"
                        data-action="increment"
                        aria-label={`Añadir ${productWithPrices.name || 'producto'}`}
                      >
                        +
                      </button>
                    </div>
                  </div>
                  <div class="aspect-[4/3] w-full rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center mb-4 overflow-hidden">
                    {productWithPrices.code ? (
                      <img
                        src={getProductCdnImageUrl(productWithPrices.code)}
                        alt={productWithPrices.name || 'Producto'}
                        loading="lazy"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      />
                    ) : (
                      <span class="material-symbols-outlined text-5xl text-slate-300">image</span>
                    )}
                  </div>
                  <div class="space-y-2">
                    <div class="flex items-start justify-between gap-4 pt-2">
                      <h3 class="text-base md:text-md font-semibold text-slate-900 leading-snug">{productWithPrices.name || 'Producto'}</h3>
                      <div class="text-right shrink-0">
                        <span class="text-md font-bold text-indigo-700">{displayPrice}</span>
                      </div>
                    </div>
                    <p class="text-sm text-slate-500 leading-relaxed">{productWithPrices.description || 'Personalizable para tu marca.'}</p>
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-20">
            <span class="material-symbols-outlined text-6xl text-slate-300 mb-4">inventory_2</span>
            <p class="text-slate-500 text-lg">
              Aún no hemos podido seleccionar productos para <strong>{companyName}</strong>.
            </p>
          </div>
        )}
      </div>

      <aside class="xl:sticky xl:top-6 space-y-4">
        <section id="presupuesto" class="relative overflow-hidden rounded-2xl border border-slate-300 bg-white p-5 shadow-xl shadow-slate-500/50 font-mono" data-company-name={companyName} data-company-slug={companySlug} data-company-email={companyEmail} data-company-id={companyId} data-tour="3">
          <span class="pointer-events-none absolute -left-3 top-20 h-6 w-6 rounded-full bg-indigo-100"></span>
          <span class="pointer-events-none absolute -right-3 top-20 h-6 w-6 rounded-full bg-indigo-100"></span>

          <div class="relative mb-4 border-b border-dashed border-slate-300 pb-4 text-center">
            <p class="mt-1 text-[10px] uppercase tracking-[0.22em] text-slate-500">MrPrinteto</p>
            <h2 class="mt-2 text-xl font-bold tracking-tight text-slate-900">Presupuesto</h2>
          </div>

          <div id="presupuesto-items" class="relative space-y-3 text-slate-800 mb-4 max-h-[44vh] overflow-auto pr-1 ">
            <p class="text-slate-500 text-sm" data-empty>Sin productos añadidos.</p>
          </div>

          <div class="relative border-t border-dashed border-slate-300 pt-4 space-y-2">
            <div id="presupuesto-savings-row" class="hidden mt-0 flex items-center justify-between text-sm text-slate-600">
              <span>Descuento</span>
              <span id="presupuesto-savings" class="font-semibold text-emerald-700 text-lg">0.00 €</span>
            </div>
            <div class="mt-1 flex items-center justify-between">
              <span class="text-base font-semibold tracking-wide text-slate-800">TOTAL</span>
              <span id="presupuesto-total" class="text-2xl font-bold tracking-tight text-indigo-700">0.00 €</span>
            </div>
          </div>

          <div class="mt-5 border-t border-dashed border-slate-300 pt-4 text-center">
            <img
              src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR7-x86h_Gr-ox3R95S6lvQp2OKbNqx7SKXjg&s"
              alt="Código de barras"
              data-html2canvas-ignore="true"
              class="mx-auto h-16 w-full max-w-[220px] object-contain opacity-80"
              loading="lazy"
            />
          </div>
        </section>

        <div class="flex flex-col gap-2 sm:gap-3">
          <button
            id="catalog-submit-btn"
            data-company-name={companyName}
            data-company-slug={companySlug}
            data-company-email={companyEmail}
            data-company-id={companyId}
            class="w-full px-4 py-2.5 rounded-full bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition-colors duration-300">
            <i class="fa-solid fa-paper-plane mr-2 text-sm"></i>
            Confirmar presupuesto</button>
          <button
            id="catalog-pdf-btn"
            data-client={companySlug}
            class="w-full px-4 py-2.5 rounded-full border-2 border-blue-600 text-blue-600 text-sm font-medium hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-all duration-300 flex items-center justify-center gap-2">
            <i class="fa-solid fa-download text-base"></i>
            Descargar
          </button>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            class="w-full px-4 py-2.5 rounded-full border-2 border-emerald-600 text-emerald-700 text-sm font-medium hover:bg-emerald-600 hover:text-white transition-all duration-300 flex items-center justify-center gap-2"
          >
            <i class="fa-brands fa-whatsapp text-lg"></i>
            ¿Necesitas ayuda?
          </a>
        </div>
      </aside>
    </div>

    <div id="catalog-notification-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 px-4" role="dialog" aria-modal="true" aria-labelledby="catalog-notification-title">
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
        <div class="mb-3 flex items-center gap-3">
          <span id="catalog-notification-icon" class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-emerald-100 text-emerald-700">
            <i class="fa-solid fa-check"></i>
          </span>
          <h3 id="catalog-notification-title" class="text-xl font-bold text-slate-900">Pedido realizado</h3>
        </div>

        <div id="catalog-confirmation-content" class="hidden space-y-4">
          <div>
            <p class="text-sm text-slate-700">Revisa el pedido antes de enviarlo:</p>
            <div id="catalog-confirmation-summary" class="mt-3 max-h-56 space-y-2 overflow-auto rounded-xl border border-slate-200 bg-slate-50 p-3 text-sm text-slate-700"></div>
          </div>
          <p class="text-sm text-slate-700">
            Al confirmar, te enviaremos un email a <span id="catalog-confirmation-client-email" class="font-semibold text-slate-900"></span> con la confirmación
            y nos pondremos en contacto contigo para acordar la producción y el pago del pedido.
          </p>
        </div>

        <p id="catalog-notification-message" class="text-sm text-slate-700"></p>
        <div class="mt-6 flex flex-wrap justify-end gap-2">
          <button id="catalog-notification-cancel" type="button" class="hidden rounded-full border border-slate-300 bg-white px-5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">Cancelar</button>
          <button id="catalog-confirmation-submit" type="button" class="hidden rounded-full bg-indigo-600 px-5 py-2 text-sm font-medium text-white hover:bg-indigo-700">Confirmar</button>
          <button id="catalog-notification-close" type="button" class="rounded-full bg-indigo-600 px-5 py-2 text-sm font-medium text-white hover:bg-indigo-700">Cerrar</button>
        </div>
      </div>
    </div>

    <footer class="mt-24 pt-12 border-t border-slate-200 flex flex-col md:flex-row justify-between items-start gap-6">
      <div class="flex flex-col items-start gap-3">
        <a href="https://mrprinteto.com" target="_blank" rel="noreferrer" class="flex items-center gap-3 text-slate-700 hover:text-slate-900 transition" aria-label="MrPrinteto">
          <img
            src="https://assets.mrprinteto.com/branding/logo/mrp-logo.png"
            alt="Logo MrPrinteto"
            class="h-16 object-cover"
            loading="lazy"
          />
        </a>
        <div class="flex gap-4 text-slate-500 text-xl">
          <a class="hover:text-slate-700 transition" href="https://mrprinteto.com" aria-label="Web MrPrinteto" target="_blank" rel="noreferrer">
            <i class="fa-solid fa-earth-europe"></i>
          </a>
          <a class="hover:text-slate-700 transition" href="https://instagram.com/mrprinteto" aria-label="Instagram @mrprinteto" target="_blank" rel="noreferrer">
            <i class="fa-brands fa-instagram"></i>
          </a>
          <a class="hover:text-slate-700 transition" href="https://www.tiktok.com/@mrprinteto" aria-label="TikTok @mrprinteto" target="_blank" rel="noreferrer">
            <i class="fa-brands fa-tiktok"></i>
          </a>
          <a class="hover:text-slate-700 transition" href="https://youtube.com/@mrprinteto" aria-label="YouTube @mrprinteto" target="_blank" rel="noreferrer">
            <i class="fa-brands fa-youtube"></i>
          </a>
          <a class="hover:text-slate-700 transition" href="https://www.threads.net/@mrprinteto" aria-label="Threads @mrprinteto" target="_blank" rel="noreferrer">
            <i class="fa-brands fa-threads"></i>
          </a>
          <a class="hover:text-slate-700 transition" href="https://discord.gg/g9c7Nhrkea" aria-label="Discord" target="_blank" rel="noreferrer">
            <i class="fa-brands fa-discord"></i>
          </a>
        </div>
      </div>
      <p class="text-slate-500 text-xs md:text-right md:whitespace-nowrap pt-12 mt-8">
        <i class="fa-solid fa-lock mr-1"></i> Los productos y precios mostrados son exclusivos para {companyName}, no son aplicables a otros clientes o para el público general. <br>
      </p>
    </footer>
  </div>
  ) : (
  <main class="min-h-screen flex flex-col items-center justify-center px-6 py-12">
    <div class="w-full max-w-md mb-4 flex items-center gap-3 rounded-xl border border-slate-300 bg-white px-8 py-2">
      <div>
        <p class="text-xs uppercase tracking-wider text-indigo-600">Portal protegido</p>
        <p class="text-sm font-semibold text-slate-800">{companyName}</p>
      </div>
      {companyLogo ? (
        <img src={companyLogo} alt={`Logo de ${companyName}`} class="ml-auto h-16 w-28 rounded-lg object-contain" loading="lazy" />
      ) : (
        <span class="ml-auto inline-flex h-16 w-16 items-center justify-center rounded-lg bg-indigo-100 text-indigo-700">
          <i class="fa-solid fa-shield-halved"></i>
        </span>
      )}
    </div>

    <section class="w-full max-w-md rounded-2xl border border-slate-300 bg-white p-6 md:p-8 shadow-xl">
      <div class="mb-5">
        <h1 class="text-2xl font-black text-indigo-600">Clave de acceso</h1>
        <p class="mt-2 text-sm text-slate-600">
          Este catálogo es exclusivo y está protegido para mantener la información privada.
        </p>
      </div>

      <form id="catalog-access-form" class="space-y-4" novalidate>
        <div>
          <input
            id="catalog-access-key"
            type="password"
            autocomplete="new-password"
            class="w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none transition focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200"
            placeholder="Introduce tu clave de acceso"
          />
          <p id="catalog-access-error" class="mt-2 hidden text-sm text-rose-600"></p>
        </div>

        <button id="catalog-access-submit" type="submit" class="w-full rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-700">
           Acceder
        </button>

        <p class="text-xs text-slate-500">
          <i class="fa-solid fa-lock mr-1"></i>
          Solo usuarios autorizados pueden acceder al contenido.
        </p>
      </form>
    </section>
  </main>
  )}

  {hasCatalogAccess ? (
  <script>
    import '../scripts/catalog-pdf.ts';
    import '../scripts/presupuesto.ts';
    import '../scripts/tour.ts';
  </script>
  ) : (
  <script is:inline>
    const form = document.getElementById('catalog-access-form');
    const keyInput = document.getElementById('catalog-access-key');
    const errorEl = document.getElementById('catalog-access-error');
    const submitBtn = document.getElementById('catalog-access-submit');

    if (form && keyInput && errorEl && submitBtn) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const key = (keyInput.value || '').trim();
        errorEl.textContent = '';
        errorEl.classList.add('hidden');

        if (!key) {
          errorEl.innerHTML = 'Debes introducir una clave.<br> Si necesitas ayuda, contacta a <u><a href="mailto:info@mrprinteto.com">info@mrprinteto.com</a></u>.';
          errorEl.classList.remove('hidden');
          return;
        }

        let navigating = false;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Autenticando...';

        try {
          const response = await fetch('/api/access', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key }),
          });

          let data = null;
          try {
            data = await response.json();
          } catch {
            data = null;
          }

          if (response.ok && data?.success) {
            navigating = true;
            submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Cargando catálogo...';
            window.location.reload();
            return;
          }

          errorEl.textContent = data?.message || 'Clave incorrecta.';
          errorEl.classList.remove('hidden');
        } catch {
          errorEl.textContent = 'No se pudo validar el acceso. Inténtalo de nuevo.';
          errorEl.classList.remove('hidden');
        } finally {
          if (!navigating) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Acceder';
          }
        }
      });
    }
  </script>
  )}

</body>

</html>

